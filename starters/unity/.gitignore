# ============================================================================
# Unity 6.x .gitignore
# Comprehensive ignore rules for Unity projects.
# ============================================================================

# ----------------------------------------------------------------------------
# Unity Generated Directories
# These are regenerated by Unity on project open. Never commit them.
# Library/ is the asset import cache (can be gigabytes).
# Temp/ is the active editor session data.
# Obj/ is intermediate build output.
# ----------------------------------------------------------------------------
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Ll]ogs/
[Mm]emoryCaptures/

# ----------------------------------------------------------------------------
# User Settings
# Editor layout, window positions, and personal preferences.
# Each developer has their own. Do not share via VCS.
# ----------------------------------------------------------------------------
[Uu]ser[Ss]ettings/

# ----------------------------------------------------------------------------
# Build Output
# Compiled game builds. Keep out of version control.
# ----------------------------------------------------------------------------
[Bb]uild/
[Bb]uilds/
[Bb]in/

# ----------------------------------------------------------------------------
# IDE / Solution Files
# Generated by Unity on project open. Regenerated automatically.
# Do not commit -- they cause constant merge conflicts.
# ----------------------------------------------------------------------------
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.VC.VC.opendb

# Visual Studio
.vs/
ExportedObj/

# JetBrains Rider
.idea/
*.iml
*.sln.DotSettings.user

# Visual Studio Code
.vscode/
*.code-workspace

# ----------------------------------------------------------------------------
# OS-Specific Files
# Generated by macOS, Windows, and Linux desktops.
# ----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# ----------------------------------------------------------------------------
# Unity Specific Ignores
# Crashlytics, code coverage, and other generated data.
# ----------------------------------------------------------------------------
crashlytics-buildid.txt
sysinfo.txt
*.unitypackage

# Asset bundles (built output, not source)
[Aa]sset[Bb]undles/
[Ss]treamingAssets/

# Unity code coverage results
CodeCoverage/

# Plastic SCM (Unity VCS)
.plastic/
*.private
*.private.meta

# ----------------------------------------------------------------------------
# Platform Build Artifacts
# Binary outputs for target platforms. Always rebuild from source.
# ----------------------------------------------------------------------------
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.ipa

# Gradle (Android build)
*.gradle
.gradle/
local.properties

# ----------------------------------------------------------------------------
# Addressables Build Cache
# Rebuilt by the Addressables system. Large and unnecessary in VCS.
# Keep AddressableAssetsData/ (config) but ignore build cache.
# ----------------------------------------------------------------------------
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/

# ----------------------------------------------------------------------------
# NuGet Packages
# If using NuGet for additional C# packages.
# ----------------------------------------------------------------------------
[Pp]ackages/

# Keep Unity's package manifest -- this is NOT NuGet, it's Unity Package Manager
!Packages/manifest.json
!Packages/packages-lock.json

# ----------------------------------------------------------------------------
# Claude Code Session Data
# Runtime session data from GameForge hooks. Never commit.
# ----------------------------------------------------------------------------
production/
.claude/logs/
