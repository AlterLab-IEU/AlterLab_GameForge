# ============================================================================
# Unreal Engine 5.x .gitignore
# Comprehensive ignore rules for Unreal Engine projects.
# ============================================================================

# ----------------------------------------------------------------------------
# Compiled Binaries
# Built by UnrealBuildTool. Regenerated on every build.
# These can be gigabytes in size. Never commit.
# ----------------------------------------------------------------------------
Binaries/

# ----------------------------------------------------------------------------
# Build Intermediates
# Compiler intermediates, hot-reload files, and link artifacts.
# Fully regenerated by the build system.
# ----------------------------------------------------------------------------
Intermediate/

# ----------------------------------------------------------------------------
# Derived Data Cache
# Engine-computed derived data (shader compilations, texture compressions).
# Massive and machine-specific. Regenerated automatically.
# ----------------------------------------------------------------------------
DerivedDataCache/

# ----------------------------------------------------------------------------
# Saved Directory
# Local saves, editor preferences, crash reports, and logs.
# Machine-specific. Each developer has their own.
# ----------------------------------------------------------------------------
Saved/

# ----------------------------------------------------------------------------
# Build Output
# Packaged game builds (cooked content, staged builds).
# This is the Build/ directory at the project root, NOT Source/Build.
# ----------------------------------------------------------------------------
Build/

# ----------------------------------------------------------------------------
# IDE / Solution Files
# Generated by UnrealBuildTool. Regenerated with GenerateProjectFiles.
# Committing these causes constant merge conflicts.
# ----------------------------------------------------------------------------
*.sln
*.VC.db
*.VC.VC.opendb
*.opensdf
*.sdf
*.suo
*.xcodeproj
*.xcworkspace

# Visual Studio
.vs/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
out/

# JetBrains Rider
.idea/
*.iml
*.sln.DotSettings.user

# Visual Studio Code
.vscode/
*.code-workspace

# Xcode
xcuserdata/
*.xcodeproj/
*.xcworkspace/

# ----------------------------------------------------------------------------
# Debug Symbols and Crash Data
# Large debug files. Not needed in version control.
# ----------------------------------------------------------------------------
*.pdb
*.ipdb
*.iobj
Crashes/
CrashReportClient/

# ----------------------------------------------------------------------------
# Hot Reload Files
# Temporary files created during live coding / hot reload sessions.
# ----------------------------------------------------------------------------
*.hotreload
*.target
*.modules

# ----------------------------------------------------------------------------
# Platform-Specific Build Artifacts
# Output from platform-specific packaging.
# ----------------------------------------------------------------------------
*.ipa
*.apk
*.aab
*.dSYM/

# ----------------------------------------------------------------------------
# Content-Related Ignores (Optional)
# Uncomment if your team builds these from source and does not commit them.
# Most teams SHOULD commit Content/ since it contains authored assets.
# ----------------------------------------------------------------------------
# Content/Collections/     # Auto-generated asset collections
# Content/Developers/      # Per-developer sandbox content

# ----------------------------------------------------------------------------
# Plugins Build Output
# Some plugins generate build artifacts in their own directories.
# Plugin source code should be committed. Build output should not.
# ----------------------------------------------------------------------------
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ----------------------------------------------------------------------------
# OS-Specific Files
# Generated by macOS, Windows, and Linux desktops.
# ----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# ----------------------------------------------------------------------------
# Unreal-Specific Temp Files
# Miscellaneous files generated during development.
# ----------------------------------------------------------------------------
*.log
*.ScreenShot.png
FileOpenOrder/
SourceArt/**/*.png
SourceArt/**/*.tga

# ----------------------------------------------------------------------------
# Claude Code Session Data
# Runtime session data from GameForge hooks. Never commit.
# ----------------------------------------------------------------------------
production/
.claude/logs/
