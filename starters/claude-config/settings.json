{
  "description": "Claude Code settings for a GameForge-powered game project. Copy to .claude/settings.json in your project root.",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(find*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf*)",
      "Bash(rm -r /)*",
      "Bash(sudo*)",
      "Bash(curl*|*sh)",
      "Bash(wget*|*sh)"
    ]
  },
  "hooks_note": "To add custom hooks (e.g., pre-commit validation, session logging), add a 'hooks' key here. See GameForge hooks/ directory for examples of session-start, validate-commit, and other lifecycle hooks."
}
