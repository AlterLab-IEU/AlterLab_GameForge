# ============================================================================
# Godot 4.x .gitignore
# Comprehensive ignore rules for Godot Engine projects.
# ============================================================================

# ----------------------------------------------------------------------------
# Godot 4 Import Cache
# The .godot/ directory contains all imported assets and editor metadata.
# It is fully regenerated from source files on project open. Never commit it.
# ----------------------------------------------------------------------------
.godot/

# ----------------------------------------------------------------------------
# Export Configuration
# export_presets.cfg may contain export passwords and signing keys.
# Commit it only if you are certain it contains no secrets.
# Use export_presets.cfg.example as a template instead.
# ----------------------------------------------------------------------------
export_presets.cfg

# ----------------------------------------------------------------------------
# Binary Translation Files
# Generated from .po or .csv source files. Regenerate from source, don't commit.
# ----------------------------------------------------------------------------
*.translation

# ----------------------------------------------------------------------------
# Godot Import Files
# .import files are metadata that Godot generates for each asset.
#
# OPTION A (recommended for teams): Track .import files.
#   They ensure consistent import settings across machines.
#   Comment out the line below to track them.
#
# OPTION B (recommended for solo devs): Ignore .import files.
#   They regenerate automatically. Reduces commit noise.
#   Uncomment the line below to ignore them.
# ----------------------------------------------------------------------------
# *.import

# ----------------------------------------------------------------------------
# Mono / C# (if using C# with Godot)
# Build artifacts from the Mono/.NET integration.
# ----------------------------------------------------------------------------
.mono/
data_*/
mono_crash.*.json

# ----------------------------------------------------------------------------
# Build Output
# Exported game builds. Keep builds out of version control.
# ----------------------------------------------------------------------------
build/
export/
*.pck
*.zip

# ----------------------------------------------------------------------------
# OS-Specific Files
# Generated by macOS, Windows, and Linux desktops.
# ----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# ----------------------------------------------------------------------------
# IDE / Editor Files
# Project files from common editors. Track only what the team agrees on.
# ----------------------------------------------------------------------------

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (Rider, IntelliJ)
.idea/
*.iml

# Vim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------------------------
# Claude Code Session Data
# Runtime session data from GameForge hooks. Never commit.
# ----------------------------------------------------------------------------
production/
.claude/logs/
